<?xml version="1.0" encoding="UTF-8"?>
<mime-info xmlns="http://www.freedesktop.org/standards/shared-mime-info">
  <mime-type type="audio/xm">
    <comment>Fast Tracker II Module</comment>
    <glob pattern="*.xm"/>
    <magic priority="50">
      <match type="string" offset="0" value="Extended Module: "/>
    </magic>
  </mime-type>
  <mime-type type="audio/mod">
    <comment>Amiga ProTracker Module</comment>
    <glob pattern="*.mod"/>
    <magic priority="40">
      <match type="string" offset="1080" value="M.K."/>
      <match type="string" offset="1080" value="M!K!"/>
      <match type="string" offset="1080" value="FLT4"/>
      <match type="string" offset="1080" value="FLT8"/>
    </magic>
  </mime-type>
  <mime-type type="audio/s3m">
    <comment>Scream Tracker 3 Module</comment>
    <glob pattern="*.s3m"/>
  </mime-type>
  <mime-type type="audio/it">
    <comment>Impulse Tracker Module</comment>
    <glob pattern="*.it"/>
    <magic priority="50">
      <match type="string" offset="0" value="IMPM"/>
    </magic>
  </mime-type>
</mime-info>
